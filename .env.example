# Application
NODE_ENV=development
APP_NAME=hermes-marketdesk
APP_PORT=3000
LOG_LEVEL=debug
TRUST_PROXY=false

# Database
DATABASE_URL=postgresql://marketdesk:marketdesk@localhost:5432/marketdesk
DB_HOST=localhost
DB_PORT=5432
DB_USER=marketdesk
DB_PASSWORD=marketdesk
DB_NAME=marketdesk
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD: leave EMPTY for no authentication (the default for local dev and
# docker-compose). When set to a non-empty value, docker-compose starts redis with
# --requirepass and the app authenticates with the same value. Do NOT wrap in quotes.
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRATION=7d

# Hermes Agent API Server (same VPS, app in Docker -> host gateway)
# Must match API_SERVER_KEY in ~/.hermes/.env for the native Hermes Agent gateway.
HERMES_API_KEY=your_local_hermes_api_server_key
HERMES_API_URL=http://host.docker.internal:8642/v1
HERMES_MODEL=hermes-agent
HERMES_REQUEST_TIMEOUT_MS=120000
HERMES_WEBHOOK_SECRET=your_hermes_webhook_secret

# External Marketplace APIs
# OLX PL real API readiness. Keep OLX_ADAPTER_MODE=stub until official OAuth
# credentials are approved and stored securely outside git. Keep live publish disabled
# until a human explicitly approves the first real listing.
OLX_MARKET=PL
OLX_ADAPTER_MODE=stub
OLX_API_BASE_URL=https://www.olx.pl/api/partner
OLX_AUTH_URL=https://www.olx.pl/oauth/authorize
OLX_TOKEN_URL=https://www.olx.pl/api/open/oauth/token
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=
OLX_REQUIRED_SCOPES=read write v2
OLX_REDIRECT_URI=http://localhost:3000/api/marketplaces/olx/oauth/callback
OLX_OAUTH_SUCCESS_URL=http://localhost:3000/marketplaces
OLX_LIVE_PUBLISH_ENABLED=false
OLX_PRICE_NEGOTIABLE=false
OLX_DELIVERY_ATTRIBUTE_CODE=
OLX_DELIVERY_OPTION_CODE=
MARKETPLACE_CREDENTIALS_KEY=
OLX_REQUEST_TIMEOUT_MS=30000
OLX_CATEGORY_IDS_JSON={}
OLX_DEFAULT_CATEGORY_ID=
OLX_CITY_ID=
OLX_DISTRICT_ID=
OLX_CONTACT_NAME=
OLX_CONTACT_PHONE=
OLX_ADVERTISER_TYPE=private
OLX_CONDITION_ATTRIBUTE_CODE=

AMAZON_API_KEY=your_amazon_api_key
AMAZON_API_SECRET=your_amazon_api_secret
EBAY_API_KEY=your_ebay_api_key
EBAY_API_SECRET=your_ebay_api_secret
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
ALIEXPRESS_API_KEY=your_aliexpress_api_key

# Notification Service
NOTIFICATION_SERVICE_URL=http://localhost:3001
NOTIFICATION_API_KEY=your_notification_api_key

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_API_URL=

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# Timezone
TIMEZONE=UTC

# Feature Flags
ENABLE_BULK_OPERATIONS=true
ENABLE_PRICE_OPTIMIZATION=false
ENABLE_INVENTORY_SYNC=true

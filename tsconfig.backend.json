{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/backend",
    "noEmit": false,
    "module": "ES2020",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "jsx": "react-jsx"
  },
  "include": [
    "src/backend/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/frontend/**/*"
  ]
}

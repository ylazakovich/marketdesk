{
  "name": "hermes-marketdesk",
  "version": "0.14.2",
  "description": "MarketDesk - Multi-marketplace product and listing management platform",
  "main": "dist/backend/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/backend/main.ts",
    "dev:frontend": "vite",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "esbuild src/backend/main.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/backend/main.js && npm run build:migrate",
    "build:migrate": "esbuild src/backend/persistence/migrate.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/backend/migrate.js",
    "build:frontend": "vite build",
    "start": "node dist/backend/main.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "verify:spec": "node scripts/verify-spec-traceability.mjs",
    "verify:compose-db": "node scripts/verify-compose-database-config.mjs",
    "verify:compose-uploads": "node scripts/verify-compose-upload-storage.mjs",
    "generate:brand-assets": "node scripts/generate-brand-assets.mjs",
    "verify:brand-assets": "node scripts/verify-brand-assets.mjs",
    "verify:migration-runner": "npm run build:migrate && node scripts/verify-migration-runner-failure.mjs",
    "verify:release-metadata": "node scripts/verify-release-metadata.mjs && node scripts/verify-release-process-lifecycle.mjs && npm run verify:migration-runner",
    "compose:release": "node scripts/compose-release.mjs",
    "db:migrate": "node --loader ts-node/esm src/backend/persistence/migrate.ts",
    "db:seed": "node --loader ts-node/esm src/backend/persistence/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --forceExit"
  },
  "keywords": [
    "marketplace",
    "product-management",
    "ecommerce",
    "hermes"
  ],
  "author": "ylazakovich",
  "license": "UNLICENSED",
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@reduxjs/toolkit": "^2.0.0",
    "axios": "^1.6.5",
    "bcryptjs": "^3.0.0",
    "bull": "^4.11.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.0.0",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "joi": "^18.0.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react-redux": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.0.0",
    "redis": "^6.0.0",
    "redux": "^5.0.0",
    "sharp": "^0.35.3",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.1",
    "@types/uuid": "11.0.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitejs/plugin-react": "6.0.3",
    "allure-jest": "3.10.2",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "concurrently": "10.0.3",
    "docker-compose": "1.4.2",
    "eslint": "10.7.0",
    "jest": "30.4.2",
    "prettier": "3.9.5",
    "supertest": "7.2.2",
    "terser": "5.49.0",
    "ts-node": "10.9.2",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "@babel/plugin-transform-runtime": "8.0.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}

{
  "name": "hermes-marketdesk",
  "version": "0.2.1",
  "description": "MarketDesk - Multi-marketplace product and listing management platform",
  "main": "dist/backend/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/backend/main.ts",
    "dev:frontend": "vite",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "esbuild src/backend/main.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/backend/main.js",
    "build:frontend": "vite build",
    "start": "node dist/backend/main.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "db:migrate": "node --loader ts-node/esm src/backend/persistence/migrate.ts",
    "db:seed": "node --loader ts-node/esm src/backend/persistence/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci"
  },
  "keywords": [
    "marketplace",
    "product-management",
    "ecommerce",
    "hermes"
  ],
  "author": "ylazakovich",
  "license": "UNLICENSED",
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.16",
    "@mui/material": "^5.14.16",
    "@reduxjs/toolkit": "^2.0.0",
    "axios": "^1.6.5",
    "bcryptjs": "^3.0.0",
    "bull": "^4.11.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^17.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@tanstack/react-query": "^4.0.5",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.20.1",
    "recharts": "^3.0.0",
    "redis": "^5.0.0",
    "redux": "^5.0.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "allure-jest": "^3.10.2",
    "concurrently": "^9.0.0",
    "docker-compose": "^0.24.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^7.0.0",
    "terser": "^5.49.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.0.0"
  }
}
